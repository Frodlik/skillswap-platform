<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="002-create-user-skills" author="skillswap">
        <createTable tableName="user_skills">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_user_skills" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_user_skills_category"
                             references="skill_categories(id)"/>
            </column>
            <column name="skill_name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="skill_level" type="INT">
                <constraints nullable="false"
                             checkConstraint="skill_level BETWEEN 1 AND 5"/>
            </column>
            <column name="type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="tags" type="TEXT[]"/>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="user_skills" indexName="idx_user_skills_user_id">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="user_skills" indexName="idx_user_skills_user_type">
            <column name="user_id"/>
            <column name="type"/>
        </createIndex>

        <sql>
            CREATE INDEX idx_user_skills_tags_gin ON user_skills USING GIN (tags);
        </sql>
    </changeSet>

</databaseChangeLog>
