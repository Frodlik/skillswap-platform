<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-skill-categories" author="skillswap">
        <createTable tableName="skill_categories">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_skill_categories" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_skill_categories_name"/>
            </column>
            <column name="parent_id" type="UUID">
                <constraints nullable="true"
                             foreignKeyName="fk_skill_categories_parent"
                             references="skill_categories(id)"/>
            </column>
            <column name="icon" type="VARCHAR(100)"/>
        </createTable>

        <createIndex tableName="skill_categories" indexName="idx_skill_categories_parent_id">
            <column name="parent_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
