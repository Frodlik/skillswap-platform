{
  "family": "api-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::695875594472:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::695875594472:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "api-gateway",
      "image": "695875594472.dkr.ecr.eu-north-1.amazonaws.com/skillswap/api-gateway:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "value": "eureka-server",
          "name": "EUREKA_HOST"
        },
        {
          "value": "https://YOUR_CLOUDFRONT_DOMAIN",
          "name": "CORS_ALLOWED_ORIGINS"
        }
      ],
      "secrets": [
        {
          "name": "JWT_PUBLIC_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:JWT_PUBLIC_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/skillswap",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8080/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
