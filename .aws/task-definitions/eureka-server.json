{
  "family": "eureka-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::695875594472:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::695875594472:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "eureka-server",
      "image": "695875594472.dkr.ecr.eu-north-1.amazonaws.com/skillswap/eureka-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8761,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "value": "eureka-server",
          "name": "EUREKA_HOST"
        }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/skillswap",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8761/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
