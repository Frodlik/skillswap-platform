{
  "family": "auth-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::695875594472:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::695875594472:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "auth-service",
      "image": "695875594472.dkr.ecr.eu-north-1.amazonaws.com/skillswap/auth-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "value": "eureka-server",
          "name": "EUREKA_HOST"
        },
        {
          "value": "true",
          "name": "COOKIE_SECURE"
        },
        {
          "value": "None",
          "name": "COOKIE_SAME_SITE"
        }
      ],
      "secrets": [
        {
          "name": "POSTGRES_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:POSTGRES_HOST::"
        },
        {
          "name": "POSTGRES_PORT",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:POSTGRES_PORT::"
        },
        {
          "name": "POSTGRES_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:POSTGRES_USER::"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:POSTGRES_PASSWORD::"
        },
        {
          "name": "RABBITMQ_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:RABBITMQ_HOST::"
        },
        {
          "name": "RABBITMQ_PORT",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:RABBITMQ_PORT::"
        },
        {
          "name": "RABBITMQ_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:RABBITMQ_USER::"
        },
        {
          "name": "RABBITMQ_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:RABBITMQ_PASSWORD::"
        },
        {
          "name": "RABBITMQ_SSL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:RABBITMQ_SSL::"
        },
        {
          "name": "JWT_PUBLIC_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:JWT_PUBLIC_KEY::"
        },
        {
          "name": "JWT_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:695875594472:secret:skillswap/prod:JWT_PRIVATE_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/skillswap",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8081/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
