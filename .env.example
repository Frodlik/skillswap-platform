# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=skillswap
POSTGRES_PASSWORD=skillswap

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Eureka
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_USER=eureka
EUREKA_PASSWORD=eureka

# Services
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
SKILL_SERVICE_PORT=8083
MATCHING_SERVICE_PORT=8084
SESSION_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086
MODERATION_SERVICE_PORT=8087

# Mail (Phase 6 — MailHog for dev SMTP capture)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
NOTIFICATIONS_FROM=noreply@skillswap.dev

# JWT (RS256 — replace with real keys in production)
JWT_PRIVATE_KEY=classpath:keys/private.pem
JWT_PUBLIC_KEY=classpath:keys/public.pem

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Observability (Phase 4)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin