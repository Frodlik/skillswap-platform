<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="002-create-content-reports" author="skillswap">
        <createTable tableName="content_reports">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_content_reports" nullable="false"/>
            </column>
            <column name="source_id" type="UUID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_content_reports_source_id"/>
            </column>
            <column name="reporter_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reported_user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="TEXT"/>
            <column name="status" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_by" type="UUID"/>
            <column name="resolved_at" type="TIMESTAMPTZ"/>
            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="content_reports" indexName="idx_content_reports_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
