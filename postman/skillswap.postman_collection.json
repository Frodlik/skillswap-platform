{
  "info": {
    "_postman_id": "skillswap-platform-collection-v2",
    "name": "SkillSwap Platform",
    "description": "End-to-end API smoke tests against the api-gateway on :8080. All endpoints are versioned (/api/v1/...). Auth is HttpOnly cookie-based: a successful Register or Login sets `access_token` and `refresh_token` as cookies, which Postman auto-stores and replays on subsequent requests (cookie jar must be enabled — it is by default). The collection persists the logged-in user_id, sample skill_id, match_id, and session_id into collection variables, so most requests are click-through after the bootstrap Auth → Skills → Matches → Sessions flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway_url",  "value": "http://localhost:8080" },
    { "key": "user_id",      "value": "" },
    { "key": "user_id_b",    "value": "" },
    { "key": "moderator_id", "value": "" },
    { "key": "skill_id",     "value": "" },
    { "key": "category_id",  "value": "" },
    { "key": "match_id",     "value": "" },
    { "key": "session_id",   "value": "" },
    { "key": "review_id",    "value": "" },
    { "key": "report_id",    "value": "" },
    { "key": "sanction_id",  "value": "" }
  ],
  "item": [

    {
      "name": "1 · Auth",
      "description": "Registration, login, refresh, logout. Auth-service sets `access_token` and `refresh_token` as HttpOnly cookies on the gateway origin. Body responses carry { userId, role, expiresIn } — tokens themselves never appear in the JSON.",
      "item": [

        {
          "name": "Register (user A)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.test('has userId',  () => pm.expect(body.userId).to.be.a('string'));",
                "pm.test('role is USER', () => pm.expect(body.role).to.eql('USER'));",
                "pm.test('expiresIn is positive number', () => pm.expect(body.expiresIn).to.be.a('number').and.to.be.above(0));",
                "pm.collectionVariables.set('user_id', body.userId);",
                "const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('access_token cookie set', () => pm.expect(setCookie).to.match(/access_token=/));",
                "pm.test('refresh_token cookie set', () => pm.expect(setCookie).to.match(/refresh_token=/));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@skillswap.dev\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/register",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },

        {
          "name": "Register (user B — for match flow)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('user_id_b', body.userId);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@skillswap.dev\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/register",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },

        {
          "name": "Register duplicate → 409",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 409', () => pm.response.to.have.status(409));",
                "pm.test('has message', () => pm.expect(pm.response.json().message).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@skillswap.dev\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/register",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },

        {
          "name": "Login (user A) — re-auths and refreshes cookies",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('user_id', body.userId);",
                "pm.test('user_id matches register', () => pm.expect(body.userId).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@skillswap.dev\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },

        {
          "name": "Login wrong password → 401",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 401', () => pm.response.to.have.status(401));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@skillswap.dev\",\n  \"password\": \"WrongPass1!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },

        {
          "name": "Refresh — rotates both cookies",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                "pm.test('access_token rotated', () => pm.expect(setCookie).to.match(/access_token=/));",
                "pm.test('refresh_token rotated', () => pm.expect(setCookie).to.match(/refresh_token=/));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/refresh",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        },

        {
          "name": "Logout — clears cookies",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 204', () => pm.response.to.have.status(204));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/logout",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        },

        {
          "name": "Login again — restore session for the rest of the run",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.collectionVariables.set('user_id', pm.response.json().userId);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@skillswap.dev\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/auth/login",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },

    {
