    {
      "name": "4 · Matches",
      "description": "Matching-service pre-computes scores whenever skills/preferences change. Wait ~5 s after the last skill add for the event to be consumed before calling /suggestions.",
      "item": [

        {
          "name": "Get suggestions for user A",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "const list = pm.response.json();",
                "pm.test('returns array', () => pm.expect(list).to.be.an('array'));",
                "if (list.length > 0) {",
                "  pm.collectionVariables.set('match_id', list[0].matchId);",
                "  pm.test('match has totalScore', () => pm.expect(list[0].totalScore).to.be.a('number'));",
                "  pm.test('match has breakdown.details', () => pm.expect(list[0].breakdown.details).to.be.an('array').with.lengthOf(7));",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/matches/suggestions/{{user_id}}?limit=10",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "matches", "suggestions", "{{user_id}}"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },

        {
          "name": "Accept match",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.test('status is ACCEPTED', () => pm.expect(pm.response.json().status).to.eql('ACCEPTED'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gateway_url}}/api/v1/matches/{{match_id}}/accept",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "matches", "{{match_id}}", "accept"]
            }
          }
        },

        {
          "name": "Match history",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/matches/history/{{user_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "matches", "history", "{{user_id}}"]
            }
          }
        },

        {
          "name": "Decline match (use a separate match — accept above already locked this one)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gateway_url}}/api/v1/matches/{{match_id}}/decline",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "matches", "{{match_id}}", "decline"]
            }
          }
        }
      ]
    },

    {
      "name": "5 · Sessions — two-phase consent + token wallet",
      "description": "Sessions start as PROPOSED with the learner's tokens placed on HOLD. The invitee (the participant who is NOT the proposer) accepts → SCHEDULED. The scheduler (or a manual PATCH) walks SCHEDULED → ACTIVE → COMPLETED. COMPLETED transfers held tokens to the teacher. ACTIVE → CANCELLED is teacher-only.",
      "item": [

        {
          "name": "Get wallet balance (user A)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('has balance, heldBalance, total', () => {",
                "  pm.expect(body.balance).to.be.a('number');",
                "  pm.expect(body.heldBalance).to.be.a('number');",
                "  pm.expect(body.total).to.be.a('number');",
                "});",
                "pm.test('signup bonus credited (balance >= 4)', () => pm.expect(body.total).to.be.at.least(4));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/user/{{user_id}}/balance",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "user", "{{user_id}}", "balance"]
            }
          }
        },

        {
          "name": "Propose session — A teaches B (status: PROPOSED, learner B's tokens HELD)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('session_id', body.id);",
                "pm.test('status is PROPOSED', () => pm.expect(body.status).to.eql('PROPOSED'));",
                "pm.test('proposerId is teacher (user A)', () => pm.expect(body.proposerId).to.eql(pm.collectionVariables.get('user_id')));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matchId\": \"{{match_id}}\",\n  \"teacherId\": \"{{user_id}}\",\n  \"learnerId\": \"{{user_id_b}}\",\n  \"proposerId\": \"{{user_id}}\",\n  \"skillName\": \"JavaScript\",\n  \"scheduledAt\": \"2099-01-01T17:00:00Z\",\n  \"durationTokens\": 1\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions"]
            }
          }
        },

        {
          "name": "Get session by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}"]
            }
          }
        },

        {
          "name": "Accept proposal — invitee = learner B (PROPOSED → SCHEDULED)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.test('status is SCHEDULED', () => pm.expect(pm.response.json().status).to.eql('SCHEDULED'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actorId\": \"{{user_id_b}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/accept",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "accept"]
            },
            "description": "Run while logged in as user B (the invitee). The proposer cannot accept their own invitation — backend returns 400."
          }
        },

        {
          "name": "Decline proposal (use on a different PROPOSED session)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actorId\": \"{{user_id_b}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/decline",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "decline"]
            },
            "description": "PROPOSED → REJECTED. Releases the learner's HOLD."
          }
        },

        {
          "name": "Promote to ACTIVE (manual; scheduler does it automatically when scheduledAt passes)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.test('status is ACTIVE', () => pm.expect(pm.response.json().status).to.eql('ACTIVE'));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\",\n  \"actorId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/status",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "status"]
            }
          }
        },

        {
          "name": "ACTIVE → CANCELLED by learner → 400 (teacher-only rule)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 400', () => pm.response.to.have.status(400));",
                "pm.test('message mentions teacher', () => pm.expect(pm.response.json().message.toLowerCase()).to.include('teacher'));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\",\n  \"actorId\": \"{{user_id_b}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/status",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "status"]
            },
            "description": "Negative test. Confirms the new rule introduced in session-service: only the teacher can abort an in-progress lesson."
          }
        },

        {
          "name": "Complete (ACTIVE → COMPLETED, transfer HOLD to teacher)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.test('status is COMPLETED', () => pm.expect(pm.response.json().status).to.eql('COMPLETED'));",
                "pm.test('completedAt is set', () => pm.expect(pm.response.json().completedAt).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\",\n  \"actorId\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/status",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "status"]
            }
          }
        },

        {
          "name": "Submit review (teacher rates learner)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('review_id', pm.response.json().id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewerId\": \"{{user_id}}\",\n  \"revieweeId\": \"{{user_id_b}}\",\n  \"rating\": 5,\n  \"comment\": \"Great learner, asked good questions.\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/review",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "review"]
            }
          }
        },

        {
          "name": "Submit report (against the other participant)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('report_id', pm.response.json().id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reporterId\": \"{{user_id}}\",\n  \"reason\": \"NO_SHOW\",\n  \"comment\": \"Learner did not join the call.\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/report",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "report"]
            },
            "description": "reason ∈ HARASSMENT|HATE_SPEECH|INAPPROPRIATE|NO_SHOW|OFF_TOPIC|SCAM|OTHER. reportedUserId is derived server-side."
          }
        },

        {
          "name": "Get Jitsi room URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/{{session_id}}/room",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "{{session_id}}", "room"]
            },
            "description": "Returns { roomName, url } — deterministic (skillswap-{sessionId}) so both participants land in the same Jitsi room."
          }
        },

        {
          "name": "List user sessions (paged)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/user/{{user_id}}?page=0&size=20",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "user", "{{user_id}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },

        {
          "name": "Get busy slots in a window",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/user/{{user_id}}/busy?from=2026-01-01T00:00:00Z&to=2026-01-08T00:00:00Z",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "user", "{{user_id}}", "busy"],
              "query": [
                { "key": "from", "value": "2026-01-01T00:00:00Z" },
                { "key": "to",   "value": "2026-01-08T00:00:00Z" }
              ]
            }
          }
        },

        {
          "name": "List token transactions (paged)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/sessions/user/{{user_id}}/transactions?page=0&size=20",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "sessions", "user", "{{user_id}}", "transactions"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "6 · Moderation (MODERATOR / ADMIN only)",
      "description": "All endpoints require the caller to have role MODERATOR or ADMIN. Promote a test user with: `docker exec skillswap-postgres psql -U skillswap -d auth_db -c \"UPDATE credentials SET role='MODERATOR' WHERE email='mod@skillswap.dev'\"`. The acting moderator's id flows through `x-user-id` (gateway sets it from the JWT subject).",
      "item": [

        {
          "name": "List pending reports",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.test('returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/reports?status=PENDING",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "reports"],
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          }
        },

        {
          "name": "Resolve report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "{{moderator_id}}" }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/reports/{{report_id}}/resolve",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "reports", "{{report_id}}", "resolve"]
            }
          }
        },

        {
          "name": "Dismiss report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "{{moderator_id}}" }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/reports/{{report_id}}/dismiss",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "reports", "{{report_id}}", "dismiss"]
            }
          }
        },

        {
          "name": "Create sanction (TEMP_BAN)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('sanction_id', pm.response.json().id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",    "value": "{{moderator_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id_b}}\",\n  \"type\": \"TEMP_BAN\",\n  \"reason\": \"Repeated no-shows.\",\n  \"expiresAt\": \"2099-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/sanctions",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "sanctions"]
            },
            "description": "type ∈ WARNING|TEMP_BAN|PERMANENT_BAN. expiresAt required for TEMP_BAN."
          }
        },

        {
          "name": "List sanctions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/sanctions?type=TEMP_BAN",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "sanctions"],
              "query": [{ "key": "type", "value": "TEMP_BAN" }]
            }
          }
        },

        {
          "name": "Get user sanctions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/users/{{user_id_b}}/sanctions",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "users", "{{user_id_b}}", "sanctions"]
            }
          }
        },

        {
          "name": "Lift sanction",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "x-user-id", "value": "{{moderator_id}}" }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/sanctions/{{sanction_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "sanctions", "{{sanction_id}}"]
            }
          }
        },

        {
          "name": "Takedown — delete user skill",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/skills/{{skill_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "skills", "{{skill_id}}"]
            },
            "description": "Proxies to skill-service's internal delete endpoint."
          }
        },

        {
          "name": "Patch user profile (moderator override)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"[redacted by moderator]\",\n  \"bio\": null\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/moderation/users/{{user_id_b}}/profile",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "moderation", "users", "{{user_id_b}}", "profile"]
            },
            "description": "Used for content-policy violations in profile fields. Proxies to user-service's internal patch endpoint."
          }
        }
      ]
    },

    {
      "name": "7 · Health & ops",
      "description": "Gateway exposes aggregated health. Each service has its own /actuator/health on its direct port.",
      "item": [

        {
