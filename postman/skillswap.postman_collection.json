    {
      "name": "3 · Skills",
      "description": "Each user adds OFFER (can teach) and WANT (wants to learn) skills. Adding/removing a skill emits an event that matching-service consumes to recompute scores.",
      "item": [

        {
          "name": "Get categories",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "const list = pm.response.json();",
                "pm.test('has at least one category', () => pm.expect(list.length).to.be.above(0));",
                "// pick the first leaf category for the next request",
                "function firstLeaf(node) { return node.children?.length ? firstLeaf(node.children[0]) : node; }",
                "pm.collectionVariables.set('category_id', firstLeaf(list[0]).id);"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gateway_url}}/api/v1/skills/categories",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "skills", "categories"]
            }
          }
        },

        {
          "name": "Add Offer (user A teaches JavaScript)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('skill_id', body.id);",
